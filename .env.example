# ============================================================
# ECOMGROWTHIA — VARIABLES DE ENTORNO (ejemplo)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a un repositorio público.
# ============================================================

# === KLARNA ===
# Panel: https://portal.klarna.com/
KLARNA_API_KEY=your_klarna_api_key_here
KLARNA_API_SECRET=your_klarna_api_secret_here
KLARNA_BASE_URL=https://api.playground.klarna.com  # Cambiar a https://api.klarna.com en producción

# === SEQURA ===
# Panel: https://sequra.es/en/developers/
SEQURA_API_KEY=your_sequra_api_key_here
SEQURA_API_SECRET=your_sequra_api_secret_here
SEQURA_BASE_URL=https://sandbox.sequrapi.com       # Cambiar a https://live.sequrapi.com en producción
SEQURA_MERCHANT_REF=your_merchant_reference_here

# === URLS DE REDIRECCIÓN ===
PAYMENT_SUCCESS_URL=https://ecomgrowthia.com/gracias
PAYMENT_CANCEL_URL=https://ecomgrowthia.com/checkout

# === PRECIOS (en céntimos) ===
# Modificar si cambian los precios
SETUP_PRICE_CENTS=150000       # 1.500,00€
MAINTENANCE_PRICE_CENTS=30000  # 300,00€ + IVA

# === NOTIFICACIONES ===
NOTIFICATION_EMAIL=info@ecomgrowthia.com
